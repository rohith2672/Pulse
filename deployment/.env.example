# deployment/.env.example
# Copy this file to deployment/.env and fill in real values.
# The .env file is git-ignored and must NEVER be committed.

# ── EC2 ───────────────────────────────────────────────────────────────────────
# Public IP or DNS of your EC2 instance.
# Used by Kafka so external clients can connect.
EC2_PUBLIC_IP=<your-ec2-public-ip>

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_USER=pulse
POSTGRES_PASSWORD=<strong-password-here>
POSTGRES_DB=pulse

# ── Kafka / Producer ──────────────────────────────────────────────────────────
KAFKA_TOPIC=orders
EVENTS_PER_SECOND=5
