# Copy this file to .env in the project root on the EC2 instance and fill in values.
# Never commit .env to git.

# PostgreSQL credentials
POSTGRES_USER=pulse
POSTGRES_PASSWORD=changeme          # use a strong password in prod
POSTGRES_DB=pulse

# EC2 public IP (used by Kafka advertised listeners)
EC2_PUBLIC_IP=<your-ec2-public-ip>

# Grafana admin password
GRAFANA_PASSWORD=changeme

# Producer throughput
EVENTS_PER_SECOND=5
